# frozen_string_literal: true

Vagrant.configure("2") do |config|
  config.vm.box = "generic/rhel8"
  config.vm.box_version = "3.0.38"
  config.vm.hostname = "rhel82-to-ol86"
  config.vm.synced_folder "../../..", "/vagrant/migrate-to-oracle-linux"

  config.vm.provider "virtualbox" do |vb|
    vb.name = "rhel82-to-ol86"
    vb.memory = 4096
    vb.cpus = 2
  end

  config.vm.provision "shell", privileged: true, inline: <<~SHELL
    set -euxo pipefail

    cd /vagrant/migrate-to-oracle-linux
    mkdir -p test-artifacts/rhel82-to-ol86

    cat /etc/os-release | tee test-artifacts/rhel82-to-ol86/source-os-release.txt
    . /etc/os-release
    test "${ID}" = "rhel"
    test "${VERSION_ID}" = "8.2"

    rpm -qa --qf '%{NAME}\\t%{EPOCHNUM}\\t%{VERSION}\\t%{RELEASE}\\t%{ARCH}\\t%{VENDOR}\\n' \
      | sort > test-artifacts/rhel82-to-ol86/source-rpms.tsv

    bash -n migrate-to-oracle-linux.sh
    ./migrate-to-oracle-linux.sh \
      --assumeyes \
      --target-version 8.6 \
      --kernel rhck \
      --no-reboot-check \
      2>&1 | tee test-artifacts/rhel82-to-ol86/migration.log

    cat /etc/os-release | tee test-artifacts/rhel82-to-ol86/target-os-release.txt
    rpm -qa --qf '%{NAME}\\t%{EPOCHNUM}\\t%{VERSION}\\t%{RELEASE}\\t%{ARCH}\\t%{VENDOR}\\n' \
      | sort > test-artifacts/rhel82-to-ol86/target-rpms.tsv

    find /var/lib/migrate-to-oracle-linux -type f -name '*.html' -print -exec cp -v {} test-artifacts/rhel82-to-ol86/ \\;
  SHELL
end
